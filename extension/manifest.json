{
  "manifest_version": 3,
  "name": "Razor ERP Auto-Fill",
  "version": "1.1",
  "description": "Auto-fill audit forms in Razor ERP",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "sidePanel"],
  "host_permissions": ["https://secureitad.razorerp.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "fill-form": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Fill form with saved template"
    },
    "fill-master-item": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      },
      "description": "Fill master item with saved template"
    }
  }
}